# Copy this file to .env.local and fill in real values. NEVER commit .env.local.

# The Flask JSON API's base URL. The browser calls this directly (no Next.js
# server proxy), so it must be set at build time and is inlined into the
# client bundle — do not put secrets here.
# Local dev default: http://127.0.0.1:5000
# Production: your deployed backend's URL (e.g. https://your-app.onrender.com)
NEXT_PUBLIC_API_URL=http://127.0.0.1:5000
