# Copy this file to .env and fill in real values. NEVER commit .env.

# GitHub personal access token (read-only scope is enough for public repos).
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Anthropic API key. Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Model to use for analysis (swappable — see docs/ARCHITECTURE.md).
# Latest options: claude-sonnet-5 (default) or claude-opus-4-8 (deeper reasoning).
ANTHROPIC_MODEL=claude-sonnet-5

# Where the SQLite cache lives (avoids re-hitting APIs on repeat analyses).
# Optional — defaults to ./.cache/resume_assistant.db
CACHE_PATH=.cache/resume_assistant.db

# The Next.js frontend's origin, allowed via CORS on the JSON API (v2.3).
# Optional — defaults to http://127.0.0.1:3000 (local dev). In production, set
# this to your deployed frontend's URL (e.g. https://your-app.vercel.app).
FRONTEND_ORIGIN=http://127.0.0.1:3000
